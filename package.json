{
  "name": "gentle-gal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port 5175",
    "build": "vite build",
    "preview": "vite preview --port 4174",
    "generate:placeholders": "node scripts/generate-placeholders.mjs",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "electron:dev": "VITE_DEV_SERVER_URL=http://localhost:5175 electron electron/main.cjs",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac"
  },
  "build": {
    "appId": "com.gentlegal.app",
    "productName": "Gentle Gal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.entertainment"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "pixi.js": "^8.18.1"
  }
}
